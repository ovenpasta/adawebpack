COMPILE=$(ADAC) -c -gnatpg -nostdinc -I../adainclude
COMPILE+=--target=wasm32 -gnateT=../target.atp
AWP_SRC=adawebpack_src/source
RTS_SRC=rts-sources

WASMRUNTIME=lib/gnat-llvm/wasm32/rts-wasm
WASMRUNTIME_EMCC=lib/gnat-llvm/wasm32/rts-wasm-emcc

# build-wasm-rts RTS_DIR MALLOC_VARIANT
# Populate and compile one WASM runtime tree.
# $(1) = destination runtime dir (e.g. lib/gnat-llvm/wasm32/rts-wasm)
# $(2) = malloc variant: "tlsf" or "emcc"
define build-wasm-rts
	$(RMDIR) $(1)/adainclude $(1)/adalib
	$(MKDIR) $(1)/adainclude $(1)/adalib
	cp -p $(AWP_SRC)/rtl/wasm32.atp $(1)/target.atp
	for f in $(COMMON_WASM_SRCS); do \
	  cp -p $(GNAT_SRC)/libgnat/$$f $(1)/adainclude; \
	done
	cp -p $(AWP_SRC)/rtl/a-elchha__wasm.adb $(1)/adainclude/a-elchha.adb
	cp -p $(RTS_SRC)/light/exceptions/a-elchha.ads $(1)/adainclude/
	cp -p $(AWP_SRC)/rtl/a-except.ad[sb] $(1)/adainclude/
	cp -p $(AWP_SRC)/rtl/s-imagei__wasm.adb $(1)/adainclude/s-imagei.adb
	cp -p $(AWP_SRC)/rtl/s-imageu__wasm.adb $(1)/adainclude/s-imageu.adb
#	cp -p $(GNAT_SRC)/hie/i-c__hie.ads $(1)/adainclude/i-c.ads
	cp -p $(RTS_SRC)/math/a-ngelfu.ad[sb] $(1)/adainclude/
	cp -p $(RTS_SRC)/math/a-nlelfu.ads $(1)/adainclude/
	cp -p $(RTS_SRC)/math/a-nuelfu.ads $(1)/adainclude/
	cp -p $(AWP_SRC)/rtl/system.ads $(1)/adainclude/
	cp -p $(RTS_SRC)/light/s-assert.adb $(1)/adainclude/
	cp -p $(AWP_SRC)/rtl/s-builti.ad[sb] $(1)/adainclude
	cp -p $(AWP_SRC)/rtl/s-finpri__wasm.adb $(1)/adainclude/s-finpri.adb
	cp -p $(GNAT_SRC)/libgnat/s-oslock__dummy.ads $(1)/adainclude/s-oslock.ads
	cp -p $(RTS_SRC)/math/s-gcmain.ad[sb] $(1)/adainclude/
	cp -p $(RTS_SRC)/full/s-init.ads $(1)/adainclude/
	cp -p $(AWP_SRC)/rtl/s-init.adb $(1)/adainclude/
	cp -p $(AWP_SRC)/rtl/s-io__wasm.adb $(1)/adainclude/s-io.adb
	cp -p $(RTS_SRC)/math/harddp/s-lidosq.adb $(1)/adainclude/
	cp -p $(RTS_SRC)/math/s-lidosq.ads $(1)/adainclude/
	cp -p $(RTS_SRC)/math/s-libdou.ad[sb] $(1)/adainclude/
	cp -p $(RTS_SRC)/math/s-libm.ad[sb] $(1)/adainclude/
	cp -p $(RTS_SRC)/math/s-libpre.ads $(1)/adainclude/
	cp -p $(RTS_SRC)/math/s-libsin.ad[sb] $(1)/adainclude/
	cp -p $(RTS_SRC)/math/hardsp/s-lisisq.adb $(1)/adainclude/
	cp -p $(RTS_SRC)/math/s-lisisq.ads $(1)/adainclude/
	cp -p $(RTS_SRC)/mem/s-memcom.ad[sb] $(1)/adainclude/
	cp -p $(RTS_SRC)/mem/s-memcop.ads $(1)/adainclude/
	cp -p $(RTS_SRC)/mem/no-cheri/s-memcop.adb $(1)/adainclude/
	cp -p $(RTS_SRC)/mem/s-memmov.ads $(1)/adainclude/
	cp -p $(RTS_SRC)/mem/no-cheri/s-memmov.adb $(1)/adainclude/
	if [ "$(2)" = "emcc" ]; then \
	  cp -p $(AWP_SRC)/rtl/s-memory__wasm_emcc.adb $(1)/adainclude/s-memory.adb; \
	else \
	  cp -p $(AWP_SRC)/rtl/s-memory__wasm.adb $(1)/adainclude/s-memory.adb; \
	  if [ "$(WASM_C_ALLOCATOR_EXPORTS)" = "no" ]; then \
	    sed -i \
	      -e 's/"malloc"/"__gnat_c_malloc"/' \
	      -e 's/"calloc"/"__gnat_c_calloc"/' \
	      -e 's/"free"/"__gnat_c_free"/' \
	      $(1)/adainclude/s-memory.adb; \
	  fi; \
	fi
	cp -p $(RTS_SRC)/mem/s-memset.ad[sb] $(1)/adainclude/
	cp -p $(RTS_SRC)/mem/no-cheri/s-memtyp.ads $(1)/adainclude/
	cp -p $(AWP_SRC)/rtl/s-parame.ads $(1)/adainclude/
	cp -p $(AWP_SRC)/rtl/s-soflin.adb $(1)/adainclude/
	cp -p $(AWP_SRC)/rtl/s-soflin.ads $(1)/adainclude/
	cp -p $(AWP_SRC)/rtl/s-stposu__wasm.adb $(1)/adainclude/s-stposu.adb
	cp -p $(AWP_SRC)/rtl/s-wchcon.ad[sb] $(1)/adainclude/
	cp -p $(AWP_SRC)/rtl/s-wchcnv.adb $(1)/adainclude/
	cp -p $(AWP_SRC)/rtl/s-wchstw__wasm.adb $(1)/adainclude/s-wchstw.adb
#	cp -p $(RTS_SRC)/zfp/s-sssita.ad[sb] $(1)/adainclude/
	cp -p $(AWP_SRC)/rtl/s-atocou__wasm.adb $(1)/adainclude/s-atocou.adb
	cp -p $(GNAT_SRC)/libgnat/s-flocon__none.adb $(1)/adainclude/s-flocon.adb
	cp -p $(RTS_SRC)/common/s-spark.ads $(1)/adainclude/
	cp -p $(RTS_SRC)/common/s-spcuop.ad[sb] $(1)/adainclude/
	cp -p $(RTS_SRC)/value/spec/s-vaispe.ad[sb] $(1)/adainclude/
	cp -p $(RTS_SRC)/value/spec/s-valspe.ad[sb] $(1)/adainclude/
	cp -p $(RTS_SRC)/value/spec/s-vauspe.ad[sb] $(1)/adainclude/
	cp -p $(RTS_SRC)/value/spec/s-vs_int.ads $(1)/adainclude/
	cp -p $(RTS_SRC)/value/spec/s-vs_uns.ads $(1)/adainclude/
	cp -p $(RTS_SRC)/value/spec_ll/s-vs_llu.ads $(1)/adainclude/
	cd $(1)/adalib && echo ">>> Pre-compile a-strmap.adb" && \
	  $(ADAC) -c -gnatpg -nostdinc -I../adainclude --target=wasm32 -gnateT=../target.atp ../adainclude/a-strmap.adb
	cd $(1)/adalib && for f in $(COMPILABLE_WASM_SPECS); do \
	  echo ">>> Compile $$f"; \
	  $(ADAC) -c -gnatpg -nostdinc -I../adainclude --target=wasm32 -gnateT=../target.atp ../adainclude/$$f || exit 1; \
	done
	cd $(1)/adalib && for f in ../adainclude/*.adb; do \
	  echo "<<< Compile $$f"; \
	  if [ $$f != '../adainclude/a-excach.adb' -a $$f != '../adainclude/s-dorepr.adb' ]; then \
	    $(ADAC) -c -gnatpg -nostdinc -I../adainclude --target=wasm32 -gnateT=../target.atp $$f || exit 1; \
	  fi \
	done
	cd $(1)/adalib && $(CHMOD) a-wx *.ali && \
	  objs=""; \
	  for f in *.o; do \
	    if [ -s "$$f" ]; then \
	      objs="$$objs $$f"; \
	    fi; \
	  done; \
	  $(AR) libgnat.a $$objs && $(LLVM_RANLIB) libgnat.a && $(RM) *.o
	echo "adainclude" > $(1)/ada_source_path
	echo "adalib" > $(1)/ada_object_path
endef

wasm: build
	$(call build-wasm-rts,$(WASMRUNTIME),tlsf)

wasm-emcc: build
	$(call build-wasm-rts,$(WASMRUNTIME_EMCC),emcc)

# CCG (C code generator) native runtime.
# sdefault.adb expects the CCG RTS at lib/gnat-llvm/<target>/rts-ccg/
# when CCG mode is active (CCG=1 env var or binary name starts with "c-").
# This target builds the native Ada runtime at that path by reusing the
# main Makefile's quicklib rule with the output directory overridden.
CCGRUNTIME=$(pwd)/lib/gnat-llvm/$(llvm_target)/rts-ccg

.PHONY: ccg
ccg: build
	$(RMDIR) $(CCGRUNTIME)
	-$(MAKE) \
	  RTS=$(CCGRUNTIME) \
	  RTSDIR=$(CCGRUNTIME)/adainclude \
	  RTSLIB=$(CCGRUNTIME)/adalib \
	  RTSOBJ=$(CCGRUNTIME)/obj-static \
	  LN_S="cp -p" quicklib
	cp -p $(RTS)/target.atp $(CCGRUNTIME)/target.atp
	echo "adainclude" > $(CCGRUNTIME)/ada_source_path
	echo "adalib" > $(CCGRUNTIME)/ada_object_path
	$(RMDIR) $(CCGRUNTIME)/obj-static
