# WASM runtime

LLVM_RANLIB=llvm-ranlib
# WASM_MALLOC selects the heap allocator for the WASM runtime:
#
#   tlsf  (default) - Ada's built-in TLSF allocator.  Ada exports "malloc",
#                     "calloc", "realloc", "free" so that all C code (SDL,
#                     libc) shares the same TLSF heap.  Good for standalone
#                     WASM targets where no host allocator is available.
#
#   emcc  - Delegate all allocation to Emscripten's dlmalloc via the standard
#           C symbols.  Ada's System.Memory thin-wraps malloc/free/realloc;
#           Ada does NOT export those symbols.  Use this when building with
#           Emscripten so that Ada, SDL, and libc all share Emscripten's heap
#           with no WASM function-table index conflicts.
WASM_MALLOC?=tlsf

# (Legacy) When WASM_MALLOC=tlsf, this controls whether the TLSF allocator
# exports the standard C names.  Must remain "yes" in the tlsf case so that
# Emscripten's dlmalloc is not a second independent allocator.
WASM_C_ALLOCATOR_EXPORTS?=yes

