project Tests is
   Use_GNATP := external ("USE_GNATP", "true");

   for Target use "llvm";
   for Object_Dir use ".objs";
   for Main use
     ("record_by_value_main.adb",
      "debug_text_signature_main.adb",
      "interfaces_c_strings_main.adb",
      "strings_fixed_main.adb");

   package Compiler is
      case Use_GNATP is
         when "true" =>
            for Switches ("Ada") use ("--target=wasm32", "-O1", "-gnatp");
         when others =>
            for Switches ("Ada") use ("--target=wasm32", "-O1");
      end case;
   end Compiler;
end Tests;
